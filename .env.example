# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (transcripción de notas de voz de accidentes) ─────────────────────
OPENAI_API_KEY=

# ── GEMA (MySQL La Carolina — fuente de datos de rotación, SOLO LECTURA) ─────
GEMA_DB_HOST=carolinainstance.c8twjwe0zioh.us-east-2.rds.amazonaws.com
GEMA_DB_PORT=3306
GEMA_DB_USER=
GEMA_DB_PASSWORD=
GEMA_DB_NAME=gema_cr

# Secreto para proteger el endpoint de cron (Vercel Cron envía Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# ── Data API externa de solo lectura (/api/external/v1) ──────────────────────
# API key estática que el consumidor (p. ej. un consultor de datos con IA) envía
# en el header x-api-key. Genere una clave larga y aleatoria: openssl rand -hex 32
DATA_API_KEY=

# ── Meta Ads (módulo Campañas — embudo de reclutamiento) ─────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0
